{
  "name": "flight-data-collector",
  "version": "0.2.14",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma --name init",
    "db:seed": "tsx packages/db/prisma/seed.ts",
    "debug:provider": "tsx apps/collector/src/debug-provider.ts",
    "debug:google-flights": "node scripts/dev-google-flights-test.mjs",
    "smoke": "pnpm --filter @flight-data-collector/dashboard smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.14.0",
    "prisma": "^5.16.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
