generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Priority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum CollectionAreaType {
  BBOX
  POLYGON
  FIR
}

enum ProviderCoverageAreaType {
  RADIUS
  BBOX
  POLYGON
}

enum ProviderIntegrationStatus {
  PLANNED
  IMPLEMENTED
  TESTING
  WORKING
  DISABLED
}

enum GeometryQuality {
  APPROXIMATE_BBOX
  OFFICIAL_POLYGON
  OFFICIAL_FIR
}

enum FetchMode {
  LIVE
  HISTORICAL
  MANUAL_TEST
}

enum TagMethod {
  BBOX
  POLYGON
  FIR
  MANUAL
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertType {
  PROVIDER_NO_DATA
  PROVIDER_LOW_VOLUME
  PROVIDER_ERROR_RATE_HIGH
  COLLECTOR_HEARTBEAT_MISSING
  PROVIDER_DEVIATION
}

enum NotificationChannel {
  DASHBOARD
  EMAIL
  WEBHOOK
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum CollectorStatus {
  STARTING
  RUNNING
  DEGRADED
  STOPPED
}

enum ReferenceDataSource {
  OURAIRPORTS
  OPENSKY_AIRCRAFT
  OPENFLIGHTS
  WIKIDATA
  PROVIDER_OBSERVED
}

enum ReferenceDataSyncStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum DetectedFlightGroupingMethod {
  PROVIDER_FLIGHT_ID
  ICAO24_CALLSIGN
  ICAO24
  CALLSIGN
}

enum FlightEnrichmentSource {
  GOOGLE_FLIGHTS_RAPIDAPI
  AERODATABOX
}

enum FlightEnrichmentStatus {
  PENDING
  SUCCESS
  NO_QUERY_POSSIBLE
  NO_MATCH
  FAILED
}

enum AdbQueryKind {
  CALLSIGN
  NUMBER
  REGISTRATION
  ICAO24
}

model Provider {
  id                       String                  @id @default(cuid())
  code                     String                  @unique
  name                     String
  enabled                  Boolean                 @default(true)
  integrationStatus        ProviderIntegrationStatus @default(PLANNED)
  supportsLive             Boolean                 @default(true)
  supportsHistorical       Boolean                 @default(false)
  baseUrl                  String?
  notes                    String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  providerCountryConfigs   ProviderCountryConfig[]
  fetchRuns                ProviderFetchRun[]
  rawResponses             RawProviderResponse[]
  rawObservations          RawFlightObservation[]
  detectedFlights          ProviderDetectedFlight[]
  observedAircraftIdentities ObservedAircraftIdentity[]
  providerDailyMetrics     ProviderDailyMetric[]
  providerCoverageAreas     ProviderCoverageArea[]
  alertRules               AlertRule[]
  alertEvents              AlertEvent[]
}

model Country {
  id                       String                  @id @default(cuid())
  iso2                     String                  @unique
  iso3                     String                  @unique
  name                     String
  enabled                  Boolean                 @default(true)
  priority                 Priority                @default(NORMAL)
  primaryUseCase           String?
  notes                    String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  collectionAreas          CollectionArea[]
  providerCountryConfigs   ProviderCountryConfig[]
  providerCoverageAreas     ProviderCoverageArea[]
  fetchRuns                ProviderFetchRun[]
  countryObservationTags   CountryObservationTag[]
  detectedFlightCountries  ProviderDetectedFlightCountry[]
  providerDailyMetrics     ProviderDailyMetric[]
  countryDailyMetrics      CountryDailyMetric[]
  alertRules               AlertRule[]
  alertEvents              AlertEvent[]
}

model CollectionArea {
  id                     String                  @id @default(cuid())
  countryId              String
  type                   CollectionAreaType
  name                   String
  bboxNorth              Float?
  bboxSouth              Float?
  bboxEast               Float?
  bboxWest               Float?
  geoJson                Json?
  firCode                String?
  geometryQuality        GeometryQuality         @default(APPROXIMATE_BBOX)
  enabled                Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  country                Country                 @relation(fields: [countryId], references: [id])
  fetchRuns              ProviderFetchRun[]
  countryObservationTags CountryObservationTag[]
}

model ProviderCoverageArea {
  id          String                   @id @default(cuid())
  providerId  String
  countryId   String
  type        ProviderCoverageAreaType @default(RADIUS)
  name        String
  enabled     Boolean                  @default(true)
  latitude    Float?
  longitude   Float?
  radiusNm    Int?
  bboxNorth   Float?
  bboxSouth   Float?
  bboxEast    Float?
  bboxWest    Float?
  geoJson     Json?
  priority    Priority                 @default(NORMAL)
  notes       String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  provider    Provider                 @relation(fields: [providerId], references: [id])
  country     Country                  @relation(fields: [countryId], references: [id])

  @@unique([providerId, countryId, name])
  @@index([providerId, countryId, enabled])
}

model ProviderCountryConfig {
  id                         String    @id @default(cuid())
  providerId                 String
  countryId                  String
  enabled                    Boolean   @default(true)
  liveEnabled                Boolean   @default(true)
  historicalEnabled          Boolean   @default(false)
  livePollingIntervalSeconds Int       @default(300)
  liveLatitude               Float?
  liveLongitude              Float?
  liveRadiusNm               Int?
  minPollingIntervalSeconds  Int?
  maxRequestsPerMinute       Int?
  maxRequestsPerHour         Int?
  maxRequestsPerDay          Int?
  maxCreditsPerDay           Int?
  priority                   Priority  @default(NORMAL)
  lowVolumeThresholdCount    Int?
  lowVolumeWindowMinutes     Int?
  noDataAlertAfterMinutes    Int?
  historicalFromDate         DateTime?
  historicalToDate           DateTime?
  notes                      String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  provider                   Provider  @relation(fields: [providerId], references: [id])
  country                    Country   @relation(fields: [countryId], references: [id])

  @@unique([providerId, countryId])
}

model ProviderFetchRun {
  id                 String               @id @default(cuid())
  providerId         String
  countryId          String?
  collectionAreaId   String?
  mode               FetchMode
  endpoint           String
  requestParamsJson  Json
  startedAt          DateTime
  finishedAt         DateTime?
  durationMs         Int?
  httpStatus         Int?
  success            Boolean
  errorCode          String?
  errorMessage       String?
  responseHash       String?
  recordCount        Int?
  rawResponseId      String?              @unique
  reviewedAt         DateTime?
  provider           Provider             @relation(fields: [providerId], references: [id])
  country            Country?             @relation(fields: [countryId], references: [id])
  collectionArea     CollectionArea?      @relation(fields: [collectionAreaId], references: [id])
  rawResponse        RawProviderResponse?
  rawObservations    RawFlightObservation[]

  @@index([providerId, countryId, startedAt], map: "idx_pfr_provider_country_started")
  @@index([success, startedAt], map: "idx_pfr_success_started")
  @@index([reviewedAt, startedAt], map: "idx_pfr_reviewed_started")
  @@index([countryId, startedAt], map: "idx_pfr_country_started")
}

model RawProviderResponse {
  id              String                 @id @default(cuid())
  providerId      String
  fetchRunId      String                 @unique
  receivedAt      DateTime
  contentType     String
  payloadJson     Json
  payloadHash     String
  byteSize        Int?
  flightProcessedAt DateTime?
  provider        Provider               @relation(fields: [providerId], references: [id])
  fetchRun        ProviderFetchRun       @relation(fields: [fetchRunId], references: [id])
  observations    RawFlightObservation[]

  @@index([providerId, receivedAt], map: "idx_rpr_provider_received")
  @@index([flightProcessedAt], map: "idx_rpr_flight_processed")
}

model RawFlightObservation {
  id                     String                  @id @default(cuid())
  providerId             String
  fetchRunId             String
  rawResponseId          String
  detectedFlightId       String?
  observedAt             DateTime
  providerAircraftId     String?
  providerFlightId       String?
  icao24                 String?
  callsign               String?
  registration           String?
  aircraftTypeIcao       String?
  operatorName           String?
  airlineIcao            String?
  airlineIata            String?
  originAirportIcao      String?
  destinationAirportIcao String?
  latitude               Float
  longitude              Float
  altitudeFt             Int?
  groundSpeedKt          Float?
  headingDeg             Float?
  verticalRateFpm        Float?
  squawk                 String?
  onGround               Boolean?
  sourceType             String?
  rawRecordJson          Json
  createdAt              DateTime                @default(now())
  provider               Provider                @relation(fields: [providerId], references: [id])
  fetchRun               ProviderFetchRun        @relation(fields: [fetchRunId], references: [id])
  rawResponse            RawProviderResponse     @relation(fields: [rawResponseId], references: [id])
  detectedFlight         ProviderDetectedFlight? @relation(fields: [detectedFlightId], references: [id])
  flightObservationLinks FlightObservationLink[]
  countryTags            CountryObservationTag[]

  @@index([observedAt], map: "idx_rfo_observed")
  @@index([providerId, observedAt])
  @@index([fetchRunId], map: "idx_rfo_fetch_run")
  @@index([providerId, fetchRunId], map: "idx_rfo_provider_fetch_run")
  @@index([rawResponseId], map: "idx_rfo_raw_response")
  @@index([icao24])
  @@index([callsign])
  @@index([detectedFlightId])
  @@index([providerId, detectedFlightId], map: "idx_rfo_provider_detected_flight")
  @@index([providerId, icao24, observedAt], map: "idx_rfo_provider_icao24_observed")
  @@index([providerId, callsign, observedAt], map: "idx_rfo_provider_callsign_observed")
}

model ProviderDetectedFlight {
  id                     String                         @id @default(cuid())
  providerId             String
  groupingMethod         DetectedFlightGroupingMethod
  groupingKey            String
  flightKey              String
  providerFlightId       String?
  icao24                 String?
  callsign               String?
  registration           String?
  aircraftTypeIcao       String?
  operatorName           String?
  firstObservedAt        DateTime
  lastObservedAt         DateTime
  observationCount       Int                            @default(0)
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  provider               Provider                       @relation(fields: [providerId], references: [id])
  observations           RawFlightObservation[]
  countries              ProviderDetectedFlightCountry[]
  enrichmentQueries      FlightEnrichmentQuery[]

  @@unique([providerId, flightKey])
  @@index([providerId, groupingKey])
  @@index([providerId, firstObservedAt])
  @@index([providerId, lastObservedAt])
  @@index([icao24])
  @@index([callsign])
}

model FlightEnrichmentQuery {
  id                         String                 @id @default(cuid())
  detectedFlightId           String
  source                     FlightEnrichmentSource
  status                     FlightEnrichmentStatus @default(PENDING)
  queryKey                   String                 @unique
  reportDate                 DateTime
  callsign                   String?
  parsedAirlineCode          String?
  parsedFlightNumber         String?
  originAirportCode          String?
  destinationAirportCode     String?
  outboundDate               String?
  endpoint                   String?
  requestParamsJson          Json
  requestedAt                DateTime?
  completedAt                DateTime?
  httpStatus                 Int?
  errorMessage               String?
  rawResponseJson            Json?
  selectedCandidateJson      Json?
  candidateCount             Int                    @default(0)
  notes                      String?
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  detectedFlight             ProviderDetectedFlight @relation(fields: [detectedFlightId], references: [id])
  candidates                 GoogleFlightsItineraryCandidate[]

  @@index([detectedFlightId, source])
  @@index([source, status, reportDate], map: "idx_feq_source_status_report_date")
  @@index([reportDate])
  @@index([parsedAirlineCode, parsedFlightNumber], map: "idx_feq_airline_flight")
  @@index([originAirportCode, destinationAirportCode, outboundDate], map: "idx_feq_route_outbound")
  @@index([requestedAt], map: "idx_feq_requested")
  @@index([completedAt], map: "idx_feq_completed")
}

model GoogleFlightsItineraryCandidate {
  id                         String                @id @default(cuid())
  enrichmentQueryId          String
  rank                       Int
  price                      Float?
  airlineCode                String?
  airlineNamesJson           Json?
  departureAirportCode       String?
  departureAirportName       String?
  arrivalAirportCode         String?
  arrivalAirportName         String?
  departureDate              String?
  departureTime              String?
  arrivalDate                String?
  arrivalTime                String?
  durationMinutes            Int?
  stops                      Int?
  aircraftName               String?
  flightNumbersJson          Json?
  detailToken                String?
  isAvailable                Boolean?
  rawCandidateJson           Json
  createdAt                  DateTime              @default(now())
  enrichmentQuery            FlightEnrichmentQuery @relation(fields: [enrichmentQueryId], references: [id])

  @@index([enrichmentQueryId, rank])
  @@index([departureAirportCode, arrivalAirportCode])
}

// AeroDataBox flight-route/schedule lookups. Cached by (queryKind:queryValue:queryDate)
// and reused across detected flights with the same identity and date. ADB is the R2
// route/itinerary enrichment source that replaced Google Flights.
model AdbFlightLookup {
  id                    String                 @id @default(cuid())
  lookupKey             String                 @unique
  queryKind             AdbQueryKind
  queryValue            String
  queryDate             String
  status                FlightEnrichmentStatus @default(PENDING)
  source                FlightEnrichmentSource @default(AERODATABOX)
  firstDetectedFlightId String?
  endpoint              String?
  httpStatus            Int?
  requestedAt           DateTime?
  completedAt           DateTime?
  errorMessage          String?
  candidateCount        Int                    @default(0)
  matchedNumber         String?
  airlineName           String?
  airlineIata           String?
  airlineIcao           String?
  departureIcao         String?
  departureIata         String?
  departureName         String?
  departureCountry      String?
  departureScheduledUtc DateTime?
  arrivalIcao           String?
  arrivalIata           String?
  arrivalName           String?
  arrivalCountry        String?
  arrivalScheduledUtc   DateTime?
  arrivalPredictedUtc   DateTime?
  aircraftModel         String?
  flightStatus          String?
  codeshareStatus       String?
  isCargo               Boolean?
  greatCircleKm         Float?
  lastUpdatedUtc        DateTime?
  selectedCandidateJson Json?
  rawResponseJson       Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([queryKind, queryValue, queryDate], map: "idx_adb_kind_value_date")
  @@index([status, queryDate], map: "idx_adb_status_date")
  @@index([departureIata, arrivalIata], map: "idx_adb_route")
}

model ProviderDetectedFlightCountry {
  id                String                 @id @default(cuid())
  detectedFlightId  String
  countryId         String
  firstObservedAt   DateTime
  lastObservedAt    DateTime
  observationCount  Int                    @default(0)
  detectedFlight    ProviderDetectedFlight @relation(fields: [detectedFlightId], references: [id])
  country           Country                @relation(fields: [countryId], references: [id])

  @@unique([detectedFlightId, countryId])
  @@index([detectedFlightId, countryId], map: "idx_pdfc_flight_country")
  @@index([firstObservedAt], map: "idx_pdfc_first_observed")
  @@index([lastObservedAt], map: "idx_pdfc_last_observed")
  @@index([countryId, firstObservedAt])
  @@index([countryId, lastObservedAt])
}

model OurAirportsAirport {
  id                 String   @id @default(cuid())
  sourceId           Int      @unique
  ident              String?
  type               String?
  name               String
  latitude           Float?
  longitude          Float?
  elevationFt        Int?
  continent          String?
  isoCountry         String?
  isoRegion          String?
  municipality       String?
  scheduledService   String?
  gpsCode            String?
  iataCode           String?
  localCode          String?
  homeLink           String?
  wikipediaLink      String?
  keywords           String?
  sourceUpdatedAt    DateTime?
  syncedAt           DateTime @default(now())
  rawCsvJson         Json

  @@index([ident])
  @@index([iataCode])
  @@index([isoCountry])
}

model OpenSkyAircraftRecord {
  id                 String   @id @default(cuid())
  icao24             String   @unique
  registration       String?
  manufacturerIcao   String?
  manufacturerName   String?
  model              String?
  typecode           String?
  serialNumber       String?
  lineNumber         String?
  icaoAircraftType   String?
  operatorName       String?
  operatorCallsign   String?
  operatorIcao       String?
  operatorIata       String?
  owner              String?
  testReg            String?
  registered         String?
  regUntil           String?
  status             String?
  built              String?
  firstFlightDate    String?
  seatConfiguration  String?
  engines            String?
  modes              Boolean?
  adsb               Boolean?
  acars              Boolean?
  notes              String?
  categoryDescription String?
  syncedAt           DateTime @default(now())
  rawCsvJson         Json

  @@index([registration])
  @@index([operatorIcao])
}

model OpenFlightsAirport {
  id             String   @id @default(cuid())
  sourceId       Int      @unique
  name           String?
  city           String?
  country        String?
  iataCode       String?
  icaoCode       String?
  latitude       Float?
  longitude      Float?
  altitudeFt     Int?
  timezone       Float?
  dst            String?
  tzDatabaseName String?
  type           String?
  source         String?
  syncedAt       DateTime @default(now())
  rawCsvJson     Json

  @@index([iataCode])
  @@index([icaoCode])
  @@index([country])
}

model OpenFlightsAirline {
  id          String   @id @default(cuid())
  sourceId    Int      @unique
  name        String?
  alias       String?
  iataCode    String?
  icaoCode    String?
  callsign    String?
  country     String?
  active      String?
  syncedAt    DateTime @default(now())
  rawCsvJson  Json

  @@index([iataCode])
  @@index([icaoCode])
  @@index([country])
}

model OpenFlightsRoute {
  id                  String   @id @default(cuid())
  sourceAirlineCode    String?
  sourceAirlineId      String?
  sourceAirportCode    String?
  sourceAirportId      String?
  destinationAirportCode String?
  destinationAirportId String?
  codeshare            String?
  stops                Int?
  equipment            String?
  syncedAt             DateTime @default(now())
  rawCsvJson           Json

  @@index([sourceAirlineCode])
  @@index([sourceAirportCode])
  @@index([destinationAirportCode])
}

model WikidataEntityPlaceholder {
  id             String   @id @default(cuid())
  entityId       String   @unique
  entityType     String?
  label          String?
  description    String?
  syncedAt       DateTime @default(now())
  rawJson        Json
}

model ReferenceDataSyncConfig {
  id             String              @id @default(cuid())
  source         ReferenceDataSource @unique
  enabled        Boolean             @default(false)
  monday         Boolean             @default(false)
  tuesday        Boolean             @default(false)
  wednesday      Boolean             @default(false)
  thursday       Boolean             @default(false)
  friday         Boolean             @default(false)
  saturday       Boolean             @default(false)
  sunday         Boolean             @default(true)
  timeOfDayLocal String              @default("03:30")
  timezone       String              @default("Europe/Berlin")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model ReferenceDataSyncRun {
  id             String                  @id @default(cuid())
  source         ReferenceDataSource
  status         ReferenceDataSyncStatus @default(RUNNING)
  startedAt      DateTime                @default(now())
  finishedAt     DateTime?
  durationMs     Int?
  recordsSeen    Int                     @default(0)
  recordsUpserted Int                    @default(0)
  errorMessage   String?
  metadataJson   Json?

  @@index([source, startedAt])
}

model ObservedAircraftIdentity {
  id                String   @id @default(cuid())
  providerId        String
  identityKey       String
  icao24            String?
  callsign          String?
  registration      String?
  aircraftType      String?
  operatorName      String?
  firstObservedAt   DateTime
  lastObservedAt    DateTime
  observationCount  Int      @default(1)
  rawExamplesJson   Json?
  provider          Provider @relation(fields: [providerId], references: [id])

  @@unique([providerId, identityKey])
  @@index([icao24])
  @@index([registration])
  @@index([operatorName])
}

model NormalizedAircraft {
  id               String   @id @default(cuid())
  icao24           String?
  registration     String?
  aircraftTypeIcao String?
  firstSeenAt      DateTime
  lastSeenAt       DateTime
}

model NormalizedFlight {
  id                     String                  @id @default(cuid())
  callsign               String?
  icao24                 String?
  registration           String?
  aircraftTypeIcao       String?
  originAirportIcao      String?
  destinationAirportIcao String?
  firstObservedAt        DateTime
  lastObservedAt         DateTime
  sourceProviderCount    Int                     @default(1)
  observationCount       Int                     @default(0)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  observationLinks       FlightObservationLink[]
}

model FlightObservationLink {
  id                    String               @id @default(cuid())
  normalizedFlightId    String
  rawFlightObservationId String
  confidenceScore       Float
  matchReason           String
  normalizedFlight      NormalizedFlight     @relation(fields: [normalizedFlightId], references: [id])
  rawFlightObservation  RawFlightObservation @relation(fields: [rawFlightObservationId], references: [id])

  @@index([normalizedFlightId], map: "idx_fol_normalized_flight")
  @@index([rawFlightObservationId], map: "idx_fol_raw_observation")
}

model CountryObservationTag {
  id                     String               @id @default(cuid())
  rawFlightObservationId String
  countryId              String
  collectionAreaId        String
  tagMethod               TagMethod
  confidenceScore         Float
  createdAt               DateTime             @default(now())
  rawFlightObservation    RawFlightObservation @relation(fields: [rawFlightObservationId], references: [id])
  country                 Country              @relation(fields: [countryId], references: [id])
  collectionArea          CollectionArea       @relation(fields: [collectionAreaId], references: [id])

  @@index([countryId], map: "idx_cot_country")
  @@index([countryId, rawFlightObservationId], map: "idx_cot_country_observation")
  @@index([rawFlightObservationId, countryId], map: "idx_cot_observation_country")
  @@index([collectionAreaId], map: "idx_cot_collection_area")
}

model ProviderDailyMetric {
  id                    String   @id @default(cuid())
  providerId            String
  countryId             String
  date                  DateTime
  liveFetchRuns         Int      @default(0)
  historicalFetchRuns   Int      @default(0)
  successfulFetchRuns   Int      @default(0)
  failedFetchRuns       Int      @default(0)
  rawResponses          Int      @default(0)
  rawObservations       Int      @default(0)
  uniqueIcao24          Int      @default(0)
  uniqueCallsigns       Int      @default(0)
  uniqueProviderFlights Int      @default(0)
  firstObservationAt    DateTime?
  lastObservationAt     DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  provider              Provider @relation(fields: [providerId], references: [id])
  country               Country  @relation(fields: [countryId], references: [id])

  @@unique([providerId, countryId, date])
  @@index([date], map: "idx_pdm_date")
  @@index([providerId, date], map: "idx_pdm_provider_date")
  @@index([countryId, date], map: "idx_pdm_country_date")
}

model CountryDailyMetric {
  id                    String   @id @default(cuid())
  countryId             String
  date                  DateTime
  rawObservations       Int      @default(0)
  uniqueIcao24          Int      @default(0)
  uniqueCallsigns       Int      @default(0)
  uniqueProviderFlights Int      @default(0)
  providerCount         Int      @default(0)
  firstObservationAt    DateTime?
  lastObservationAt     DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  country               Country  @relation(fields: [countryId], references: [id])

  @@unique([countryId, date])
  @@index([date], map: "idx_cdm_date")
}

model AlertRule {
  id                      String              @id @default(cuid())
  code                    String              @unique
  name                    String
  enabled                 Boolean             @default(true)
  severity                AlertSeverity
  alertType               AlertType
  providerId              String?
  countryId               String?
  evaluationWindowMinutes Int
  thresholdValue          Float?
  cooldownMinutes         Int
  notificationChannel     NotificationChannel @default(DASHBOARD)
  notificationTarget      String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  provider                Provider?           @relation(fields: [providerId], references: [id])
  country                 Country?            @relation(fields: [countryId], references: [id])
  events                  AlertEvent[]
}

model AlertEvent {
  id              String        @id @default(cuid())
  alertRuleId     String
  severity        AlertSeverity
  status          AlertStatus   @default(OPEN)
  providerId      String?
  countryId       String?
  message         String
  measuredValue   Float?
  thresholdValue  Float?
  windowStart     DateTime
  windowEnd       DateTime
  triggeredAt     DateTime
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  alertRule       AlertRule     @relation(fields: [alertRuleId], references: [id])
  provider        Provider?     @relation(fields: [providerId], references: [id])
  country         Country?      @relation(fields: [countryId], references: [id])

  @@index([status, severity])
}

model CollectorHeartbeat {
  id           String          @id @default(cuid())
  serviceName  String
  hostname     String
  processId    Int?
  startedAt    DateTime
  lastSeenAt   DateTime
  status       CollectorStatus
  version      String?
  metadataJson Json?

  @@unique([serviceName, hostname])
}
